# App
CHAT_HACKSMAN_DB_PATH=./data/chat_hacksman.db
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
REPO_URL=https://github.com/romkey/pdxhackerspace-chat-hacksman

# Topics feed (buttons in UI)
RAG_TOPICS_URL=https://members.pdxhackerspace.org/rag.json
TOPICS_CACHE_TTL_SECONDS=300

# Qdrant (optional RAG)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
RAG_COLLECTIONS=
RAG_COLLECTION_1=
RAG_COLLECTION_2=
RAG_COLLECTION_3=
RAG_COLLECTION_4=
RAG_COLLECTION_5=
RAG_TOP_K=4
RAG_TOP_K_EVENTS=3
RAG_TOP_K_SLACK=3
RAG_TOP_K_CALIBRE=2
RAG_MIN_SCORE=0.5

# Embeddings for RAG retrieval (optional; if unavailable, RAG is skipped gracefully)
EMBEDDING_URL=http://localhost:11434
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_CONTEXT_LENGTH=8192
EMBEDDING_TIMEOUT_SECONDS=30

# LLM request resilience (covers both Ollama and llama.cpp)
LLM_TIMEOUT_SECONDS=180
LLM_RETRY_ATTEMPTS=2
LLM_RETRY_BACKOFF_SECONDS=0.5

# Default model settings
DEFAULT_PROVIDER=ollama
DEFAULT_LLM_BASE_URL=http://localhost:11434
DEFAULT_MODEL=llama3.2:latest
DEFAULT_SYSTEM_PROMPT=You are Chat Hacksman, an expert assistant for hackerspace members.

# Optional HTTP basic auth for all endpoints except /health
BASIC_AUTH_USERNAME=
BASIC_AUTH_PASSWORD=
